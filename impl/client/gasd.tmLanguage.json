{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "GASD",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#literal_types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.gasd",
                    "match": "\\b(VERSION|CONTEXT|TARGET|TRACE|NAMESPACE|IMPORT|AS|RESOURCES|DECISION|CHOSEN|RATIONALE|ALTERNATIVES|AFFECTS|TYPE|COMPONENT|PATTERN|DEPENDENCIES|INTERFACE|FLOW|VALIDATE|ENSURE|OTHERWISE|ACHIEVE|CREATE|PERSIST|TRANSFORM|RETURN|LOG|ON_ERROR|THROW|THROWS|EXECUTE|UPDATE|APPLY|WITH|MATCH|DEFAULT|IF|ELSE|STRATEGY|ALGORITHM|PRECONDITION|POSTCONDITION|COMPLEXITY|IS|NOT|AND|OR|INPUT|OUTPUT|SORT_KEY|ORDER|ASCENDING|CONSTRAINT|INVARIANT|LOCAL|GLOBAL|QUESTION|APPROVE|STATUS|BLOCKING|BY|DATE|NOTES|TODO|REVIEW|IS_SORTED|CONTRACT|BEHAVIORS|CASE|AFTER|IDEMPOTENT|TIMEOUT|DEPENDS_ON|STEP|ASSUMPTION|CONSEQUENCE|MODEL|VERIFIES|ASSUMPTIONS)\\b"
                },
                {
                    "name": "constant.language.gasd",
                    "match": "\\b(true|false|null)\\b"
                },
                {
                    "name": "storage.type.gasd",
                    "match": "\\b(String|Integer|Float|Decimal|Boolean|Bytes|UUID|DateTime|List|Map|Optional|Result|Enum|Any|Void)\\b"
                },
                {
                    "name": "variable.language.gasd",
                    "match": "@[a-zA-Z_]+"
                }
            ]
        },
        "literal_types": {
            "name": "storage.type.literal.gasd",
            "match": "(?<=:)\\s*(\"[^\"]*\")"
        },
        "strings": {
            "name": "string.quoted.double.gasd",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.gasd",
                    "match": "\\\\."
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.documentation.gasd",
                    "begin": "\\/\\/\\/",
                    "end": "$"
                },
                {
                    "name": "comment.line.double-slash.gasd",
                    "begin": "\\/\\/",
                    "end": "$"
                },
                {
                    "name": "comment.block.gasd",
                    "begin": "\\/\\*",
                    "end": "\\*\\/"
                }
            ]
        }
    },
    "scopeName": "source.gasd"
}