/* 
   --- Acceptance Test Suite: GASD 1.1 ---
   Verifies user stories and ACs for the VS Code extension.
   Focus: Syntax highlighting, Literal Types, Completion Casing.
*/
CONTEXT: "VS Code Extension Testing"
TARGET: "TypeScript (Mocha)"
TRACE: #US-28, #AC-28.1, #AC-28.4, #AC-5.4

IMPORT "design/types.gasd" AS Types

NAMESPACE: "gasd.vscode.tests.acceptance"

TYPE TestResult:
    status: Enum(PASS, FAIL)
    message: String

FLOW verify_literal_type_highlighting:
    ACHIEVE "Open types.gasd"
    ACHIEVE "Navigate to 'status: \"Success\"'"
    VALIDATE "Value is highlighted as String Literal" AS TYPE.TestResult @trace #AC-28.1

FLOW verify_completion_casing:
    ACHIEVE "Open new .gasd file"
    ACHIEVE "Type 'flow'"
    ACHIEVE "Trigger Completion"
    ENSURE "Completion list contains 'FLOW'"
    ACHIEVE "Select 'FLOW'"
    ENSURE "Injected text is 'FLOW'" @trace #AC-5.4

FLOW run_acceptance_suite:
    ACHIEVE "Invoke verify_literal_type_highlighting"
    ACHIEVE "Invoke verify_completion_casing"
