/* 
   --- Regression Test Suite: GASD 1.1 ---
   Prevents recurrence of past bugs.
   Focus: Indentation errors, Type resolution.
*/
CONTEXT: "VS Code Extension Testing"
TARGET: "TypeScript (Mocha)"
TRACE: #US-28, #AC-3.2, #AC-9.1

IMPORT "design/types.gasd" AS Types

NAMESPACE: "gasd.vscode.tests.regression"

TYPE TestStatus:
    message: String

FLOW verify_auto_indentation:
    ACHIEVE "Open new .gasd file"
    ACHIEVE "Type 'TYPE Test:' and press Enter"
    VALIDATE "Cursor is indented by 4 spaces" AS TYPE.TestStatus @trace #AC-3.2

FLOW verify_diagnostic_clearance:
    ACHIEVE "Introduce Syntax Error"
    ENSURE "Diagnostic exists"
    ACHIEVE "Fix Syntax Error"
    ENSURE "Diagnostic is cleared" @trace #AC-9.1

FLOW run_regression_suite:
    ACHIEVE "Invoke verify_auto_indentation"
    ACHIEVE "Invoke verify_diagnostic_clearance"
