# Reference Implementation

## Complete Formal EBNF Grammar (GASD 1.2)

This grammar includes every GASD 1.1 production rule **verbatim and unmodified**, plus GASD 1.2 additions marked with `(* GASD 1.2 addition *)`. No GASD 1.1 rule has been altered or removed.

```ebnf
(* ══════════════════════════════════════════════════════════════ *)
(* GASD 1.2 Grammar                                             *)
(* Includes complete GASD 1.1 grammar + GASD 1.2 additions      *)
(* GASD 1.1 rules are UNCHANGED — 1.2 additions clearly marked  *)
(* ══════════════════════════════════════════════════════════════ *)

(* --- Top-level file structure --- *)

gasd_file     ::= { section }
section       ::= context_dir | namespace_stmt | import_stmt | decision_blk
                | type_def | component_def | flow_def | strategy_def
                | constraint | resources_stmt
                | version_stmt                            (* GASD 1.2 addition *)
                | contract_def                             (* GASD 1.2 addition *)
                | model_def                                (* GASD 1.2 addition *)
                | assumption_def                           (* GASD 1.2 addition *)

resources_stmt::= "RESOURCES" ":" indent { resource_item } dedent
resource_item ::= "-" string_literal [ annotations ]

(* --- Context & Directives --- *)

context_dir   ::= ( "CONTEXT" | "TARGET" | "TRACE" ) ":" value { "," value }
namespace_stmt::= "NAMESPACE" ":" string_literal
import_stmt   ::= "IMPORT" string_literal [ "AS" identifier ]
value         ::= string_literal | number_literal | boolean_literal

(* GASD 1.2 addition *)
version_stmt  ::= "VERSION" version_number
version_number::= number_literal "." number_literal [ "." number_literal ]

(* --- Decisions --- *)

decision_blk  ::= "DECISION" string_literal [ annotations ] ":" indent
                  "CHOSEN" ":" string_literal
                  [ "RATIONALE" ":" string_literal ]
                  [ "AFFECTS" ":" list_literal ]
                  dedent

(* --- Types --- *)

type_def      ::= "TYPE" identifier [ annotations ] ":" indent
                  { field_def }
                  dedent

field_def     ::= identifier ":" type_expr [ annotations ]

type_expr     ::= identifier
                | string_literal    (* Allows "Todo", "Review", etc. *)
                | number_literal    (* Allows 200, 404, etc. *)
                | "List" "<" type_expr ">"
                | "Map" "<" type_expr "," type_expr ">"
                | "Enum" "(" (identifier | string_literal) { "," (identifier | string_literal) } ")"
                | "Optional" "<" type_expr ">"

(* --- Components --- *)

component_def ::= "COMPONENT" identifier [ annotations ] ":" indent
                  [ "PATTERN" ":" string_literal ]
                  [ "DEPENDENCIES" ":" list_literal ]
                  "INTERFACE" ":" indent
                  { method_sig }
                  dedent dedent

method_sig    ::= identifier "(" [ param_list ] ")" "->" type_expr

(* --- Flows --- *)

flow_def      ::= "FLOW" identifier "(" [ param_list ] ")" [ "->" type_expr ] ":" indent
                  { flow_step }
                  dedent

flow_step     ::= step_number "." ( action | control_flow )
                  [ depends_clause ]                       (* GASD 1.2 addition *)
                  [ annotations ]

action        ::= "VALIDATE" expr asBinding
                | "ACHIEVE" string_literal [ ":" achieve_body ] [ block ]   (* GASD 1.2: achieve_body added *)
                | "CREATE" identifier ":" block
                | "PERSIST" identifier "via" identifier
                | "UPDATE" identifier "SET" identifier "=" expr
                | "APPLY" identifier "TO" expr
                | "THROW" identifier [ "(" arg_list ")" ]
                | "RETURN" expr
                | "LOG" string_literal

asBinding     ::= "AS" typePath
typePath      ::= "TYPE" "." typeIdentifier { "." fieldIdentifier }
typeIdentifier::= IDENTIFIER
fieldIdentifier::= IDENTIFIER

assignments   ::= property { "," property }

control_flow  ::= "ENSURE" condition [ "OTHERWISE" action ]
                | "MATCH" expr ":" indent { match_case } dedent
                | "IF" condition ":" indent { flow_step } dedent [ "ELSE" ":" indent { flow_step } dedent ]

match_case    ::= pattern_list "->" ( flow_step | action )
pattern_list  ::= pattern { "|" pattern }
pattern       ::= [ "CONTAINS" ] ( string_literal | number_literal | identifier | "DEFAULT" )

block         ::= indent { property | annotation | flow_step | on_error_clause } dedent
on_error_clause ::= "ON_ERROR" ":" action
property      ::= identifier ":" value

value         ::= string_literal | number_literal | boolean_literal | identifier | expr

expr          ::= term { bin_op term }
term          ::= "TRANSFORM" "(" value "," annotations ")"
                | value
                | identifier { "." identifier } [ "(" [ arg_list ] ")" ]
bin_op        ::= "+" | "-" | "*" | "/" | "^" | "==" | "!=" | ">" | "<" | ">=" | "<="
arg_list      ::= value { "," value }

(* --- Strategies --- *)

strategy_def  ::= "STRATEGY" identifier [ annotations ] ":" indent
                  "ALGORITHM" ":" string_literal
                  [ "PRECONDITION" ":" condition ]
                  [ "COMPLEXITY" ":" string_literal ]
                  [ "INPUT" ":" param_list ]
                  [ "OUTPUT" ":" type_expr ]
                  dedent

(* --- Constraints & Invariants --- *)

constraint    ::= ( "CONSTRAINT" | "ENSURE" ) ":" string_literal
                | invariant_def

invariant_def ::= "INVARIANT" [ scope_qualifier ] ":" string_literal   (* GASD 1.2: scope_qualifier added *)

(* GASD 1.2 addition *)
scope_qualifier ::= "LOCAL" | "GLOBAL"

(* --- Lexical Tokens --- *)

identifier    ::= [a-zA-Z_#] { [a-zA-Z0-9_.-] }
string_literal::= '"' { character } '"'
step_number   ::= digit { digit }
indent        ::= (* implied indentation increase *)
dedent        ::= (* implied indentation decrease *)
param_list    ::= param { "," param }
param         ::= identifier ":" type_expr
list_literal  ::= "[" value { "," value } "]"
condition     ::= expr

(* --- Annotations (GASD 1.2: extended with AS identifier) --- *)

annotations   ::= annotation { annotation }
annotation    ::= "@" identifier [ "(" value_list ")" ] [ "AS" identifier ]    (* GASD 1.2: AS clause added *)
value_list    ::= value { "," value }

(* ══════════════════════════════════════════════════════════════ *)
(* GASD 1.2 NEW CONSTRUCTS — additions only, no 1.1 changes     *)
(* ══════════════════════════════════════════════════════════════ *)

(* --- ACHIEVE POSTCONDITION (GASD 1.2 addition) --- *)

achieve_body  ::= indent
                  [ "POSTCONDITION" ":" indent { postcondition_expr } dedent ]
                  [ on_error_clause ]
                  [ "TIMEOUT" ":" duration_literal ]
                  dedent

postcondition_expr ::= expr comparison_op expr
comparison_op ::= "IS" | "==" | "!=" | ">" | "<" | ">=" | "<="
duration_literal ::= number_literal ( "ms" | "s" | "m" )

(* --- DEPENDS_ON (GASD 1.2 addition) --- *)

depends_clause ::= "DEPENDS_ON" step_ref { "," step_ref }
step_ref       ::= "STEP" step_number

(* --- CONTRACT (GASD 1.2 addition) --- *)

contract_def  ::= "CONTRACT" qualified_name ":" indent
                  "INPUT" ":" param_list
                  "OUTPUT" ":" type_expr
                  "BEHAVIORS" ":" indent { case_def } dedent
                  [ "IDEMPOTENT" ":" boolean_literal ]
                  [ "VERSION" ":" string_literal ]
                  dedent

case_def      ::= "CASE" identifier ":" indent
                  { case_clause }
                  dedent

case_clause   ::= "POSTCONDITION" ":" postcondition_expr
                | "THROWS" ":" identifier
                | "AFTER" ":" ( duration_literal | identifier "(" value_list ")" )

qualified_name ::= identifier { "." identifier }

(* --- MODEL (GASD 1.2 addition) --- *)

model_def     ::= "MODEL" string_literal ":" indent
                  "TYPE" ":" model_type
                  "FILE" ":" string_literal
                  [ "VERIFIES" ":" indent { invariant_ref } dedent ]
                  [ "ASSUMPTIONS" ":" indent { string_literal } dedent ]
                  dedent

model_type    ::= "TLA+" | "Alloy" | "Spin" | "Promela" | string_literal
invariant_ref ::= invariant_def | "INVARIANT" scope_qualifier ":" string_literal

(* --- ASSUMPTION (GASD 1.2 addition) --- *)

assumption_def ::= "ASSUMPTION" string_literal ":" indent
                   [ "AFFECTS" ":" list_literal ]
                   [ "CONSEQUENCE" ":" string_literal ]
                   dedent
                 | "ASSUMPTION" ":" string_literal           (* inline form *)

(* ══════════════════════════════════════════════════════════════ *)
(* END OF GASD 1.2 GRAMMAR                                      *)
(* ══════════════════════════════════════════════════════════════ *)
```

## AST Node Additions

| New Node Type | Parent | Fields |
|---|---|---|
| `PostconditionNode` | `AchieveNode` | `expressions: List<PostconditionExpr>` |
| `ContractNode` | Root | `target, input, output, cases: List<CaseNode>, version, idempotent` |
| `CaseNode` | `ContractNode` | `name, postconditions, throws, after` |
| `DependsOnNode` | `FlowStepNode` | `step_refs: List<Integer>` |
| `ModelNode` | Root | `name, type, file, verifies, assumptions` |
| `AssumptionNode` | Root | `description, affects, consequence` |
| `VersionNode` | Root | `major, minor, patch` |
| `ObligationIdNode` | `AnnotationNode` | `identifier: String` |

