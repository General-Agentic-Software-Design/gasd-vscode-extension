/* 
   --- Validation Spec: Extension Orchestrator ---
   Based on design/vscode_gasd_extension.gasd
*/
CONTEXT: "VS Code Extension / LSP"
TARGET: "TypeScript 5.x"
TRACE: #US-28

IMPORT "design/vscode_gasd_extension.gasd" AS Main

NAMESPACE: "gasd.vscode.validation"

TYPE Requirement:
    name: String

FLOW validate_system_compliance:
    VALIDATE "Decision 'Process Model' is Multi-process" AS TYPE.Requirement
    VALIDATE "Decision 'Strict Compliance' is Normative 1.1.0" AS TYPE.Requirement
    
    ACHIEVE "Check Resources List"
    ENSURE "icons/gasd_icon.png exists in resources"

FLOW run_orchestrator_validation:
    ACHIEVE "Invoke validate_system_compliance"
