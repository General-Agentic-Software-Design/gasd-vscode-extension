/* 
   --- Validation Spec: Test Suite ---
   Based on design/tests.gasd
*/
CONTEXT: "VS Code Extension Testing"
TARGET: "TypeScript (Mocha/Playwright-VSCode)"
TRACE: #US-28

IMPORT "design/tests.gasd" AS Testing

NAMESPACE: "gasd.vscode.validation"

TYPE Requirement:
    name: String

FLOW validate_testing_patterns:
    ACHIEVE "Verify verify_lsp_features flow"
    VALIDATE "Contains explicit AS TYPE binding" AS TYPE.Requirement
    
    ACHIEVE "Verify verify_linting_and_fixes flow"
    VALIDATE "Wait for diagnostics" AS TYPE.Requirement

FLOW run_test_validation:
    ACHIEVE "Invoke validate_testing_patterns"
