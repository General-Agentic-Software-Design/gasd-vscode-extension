/* 
   --- Validation Spec: Core Types ---
   Based on design/types.gasd
*/
CONTEXT: "VS Code Extension / LSP"
TARGET: "TypeScript 5.x"
TRACE: #US-28

IMPORT "design/types.gasd" AS Types

NAMESPACE: "gasd.vscode.validation"

TYPE Requirement:
    name: String

TYPE Position:
    line: Integer
    character: Integer

TYPE Void:
    status: "Success"

FLOW validate_types_logic:
    ACHIEVE "Create Valid Position"
    VALIDATE result AS TYPE.Position
    
    ACHIEVE "Create Invalid Position (Negative)"
    VALIDATE result AS TYPE.Position
       ON_ERROR: LOG "Correctly caught out-of-range line"

    ACHIEVE "Create Literal Match (Success)"
    VALIDATE result AS TYPE.Void
    
    ACHIEVE "Create Literal Match (Fail)"
    VALIDATE result AS TYPE.Void
       ON_ERROR: LOG "Correctly caught literal mismatch"

FLOW run_type_validation:
    ACHIEVE "Invoke validate_types_logic"
