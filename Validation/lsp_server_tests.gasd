/* 
   --- Validation Spec: LSP Server ---
   Based on design/lsp_server.gasd
*/
CONTEXT: "VS Code Extension / LSP"
TARGET: "TypeScript 5.x"
TRACE: #US-28

IMPORT "design/lsp_server.gasd" AS Server

NAMESPACE: "gasd.vscode.validation"

TYPE Requirement:
    name: String

FLOW validate_lsp_server_logic:
    ACHIEVE "Mock Document Change"
    VALIDATE result AS TYPE.Requirement
    
    ACHIEVE "Mock Syntax Error"
    MATCH "Parse Result":
        "LEX_ERROR" | "PARSE_ERROR" -> LOG "Error correctly identified"
    
    ACHIEVE "Mock Transform"
    RETURN TRANSFORM(result, @encode("LSP-Semantic-Tokens"))

FLOW run_server_validation:
    ACHIEVE "Invoke validate_lsp_server_logic"
