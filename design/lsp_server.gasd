/* 
   --- GASD LSP Server Design (Expert Strict) ---
   Logic for language analysis, agentic interaction, and advanced LSP features.
   Strictly follows GASD 1.1.0 normative specification:
   https://github.com/General-Agentic-Software-Design/General-Agentic-Software-Design-Language
*/
CONTEXT: "VS Code Extension / LSP"
TARGET: "TypeScript 5.x"
TRACE: #US-5 to #US-9, #US-13, #US-18, #US-19, #US-21, #US-22, #US-23, #US-25, #US-26, #US-28

IMPORT "types.gasd" AS Types

NAMESPACE: "gasd.lsp.server"

COMPONENT GASDServer @trace #US-5 to #US-9, #US-18 to #US-26:
    PATTERN: "Language Server"
    DEPENDENCIES: [Parser, AgentService, SymbolManager]
    
    INTERFACE:
        on_initialize(params: Map<String, Any>) -> Map<String, Any>
        on_document_change(uri: String, content: String) -> List<Types.Diagnostic>
        on_hover(uri: String, pos: Types.Position) -> Optional<Types.Hover> @trace #US-7
        on_completion(uri: String, pos: Types.Position) -> List<Types.CompletionItem> @trace #US-5
        on_definition(uri: String, pos: Types.Position) -> Optional<Types.Location> @trace #US-6
        on_signature_help(uri: String, pos: Types.Position) -> Optional<Types.SignatureHelp> @trace #US-22
        on_document_symbols(uri: String) -> List<Types.SymbolInformation> @trace #US-19
        on_code_actions(uri: String, range: Types.Range, context: CodeActionContext) -> List<CodeAction> @trace #US-18, #AC-18.3
        on_semantic_tokens(uri: String) -> SemanticTokens @trace #US-21
        on_inlay_hints(uri: String, range: Types.Range) -> List<Types.InlayHint> @trace #US-23
        on_rename(uri: String, pos: Types.Position, newName: String) -> Types.WorkspaceEdit @trace #US-8
        on_formatting(uri: String, options: Types.FormattingOptions) -> List<Types.TextEdit> @trace #US-4, #AC-4.3
        on_type_formatting(uri: String, pos: Types.Position, ch: String) -> List<Types.TextEdit> @trace #AC-4.4
        on_workspace_symbols(query: String) -> List<Types.SymbolInformation> @trace #US-20
        on_selection_range(uri: String, positions: List<Types.Position>) -> List<Types.SelectionRange> @trace #US-24
        on_call_hierarchy(uri: String, pos: Types.Position) -> List<Types.CallHierarchyItem> @trace #US-25
        on_document_highlight(uri: String, pos: Types.Position) -> List<Types.DocumentHighlight> @trace #US-26

COMPONENT Parser @trace #AC-9.1, #AC-21.1:
    INTERFACE:
        parse(content: String) -> Result<AST>
        get_semantic_tokens() -> SemanticTokens
        get_outline() -> List<Types.SymbolInformation>
        get_folding_ranges() -> List<Range> @trace #US-3

COMPONENT ValidationEngine @trace #US-17:
    INTERFACE:
        check_compatibility(ast: AST, target: String) -> List<Types.Diagnostic> @trace #AC-17.1

COMPONENT VisualizationService @trace #US-14:
    INTERFACE:
        generate_flowchart(flow_id: String) -> String @trace #AC-14.1

COMPONENT TraceabilityService @trace #US-11:
    INTERFACE:
        get_coverage_report() -> Map<String, Any> @trace #AC-11.1

COMPONENT AgentService @trace #US-10, #US-13:
    INTERFACE:
        ask_question(context: String, question: String) -> String
        draft_design(requirement: String) -> String

// --- Flows ---

/// Implements #US-9 (Diagnostics) & #US-18 (Code Actions)
FLOW validate_document(uri: String, content: String):
    @trace #AC-9.1, #AC-9.2, #AC-18.1, #US-28
    1. ACHIEVE "Run Parser.parse(content)"
    2. MATCH result:
        "PARSE_ERROR" | "LEX_ERROR" -> 
            CREATE Types.Diagnostic:
                message: "Syntax Error"
                severity: ERROR
            ACHIEVE "Generate Quick Fixes for typos" @trace #AC-18.1
        "SUCCESS" -> 
            VALIDATE "Directives (CONTEXT, TARGET) exist" AS TYPE.Requirement @trace #AC-9.2
            ON_ERROR: ACHIEVE "Report Missing Directives" @trace #AC-18.2
    3. PERSIST diagnostics via LSP connection

/// Implements #US-13 (Human-in-the-Loop)
FLOW handle_agent_loop(question: String):
    @trace #AC-13.1, #AC-13.2
    1. CREATE Types.Diagnostic for the `QUESTION` block
    2. ACHIEVE "UI: Show CodeLens 'Answer Agent'" @trace #AC-13.2
    3. ACHIEVE "AgentService.ask_question(..., question)"
    4. RETURN "decision"

/// Implements #US-21 (Semantic Highlighting)
FLOW provide_semantic_tokens(uri: String):
    @trace #AC-21.1
    1. ACHIEVE "Parser.get_semantic_tokens()"
    2. RETURN TRANSFORM(tokens, @encode("LSP-Semantic-Tokens"))

/// Implements #AC-5.4 (Spec-Correct Completion Casing)
/// Completions MUST use textEdit (not insertText) to force EBNF-correct casing.
FLOW provide_completions(uri: String, pos: Types.Position):
    @trace #AC-5.1, #AC-5.4
    1. ACHIEVE "Compute prefix range: scan backward from cursor to find word start"
    2. CREATE CompletionItem for each keyword, type, and annotation:
        textEdit: Types.TextEdit replacing prefix range with spec-correct text
        filterText: lowercase version (so user can type in any case)
    3. RETURN List<CompletionItem>

/// Implements #AC-4.4 (On-Type Auto-Correction)
FLOW autocorrect_keyword_on_type(uri: String, pos: Types.Position, ch: String):
    @trace #AC-4.4
    1. ACHIEVE "Get current and previous line content"
    2. MATCH keyword case:
        "lowercase" -> CREATE Types.TextEdit to uppercase the keyword
        "UPPERCASE" -> RETURN (no edit needed)
    3. RETURN edits

// --- Global Invariants ---
INVARIANT: "Expert Compliance: LSP Server must strictly validate against GASD 1.0.0 EBNF."
